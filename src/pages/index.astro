---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { monthYear, readingTime } from '../lib/reading';
import { siteDescription, siteTagline, siteTitle, siteUrl } from '../lib/site';

const [articleEntries, experimentEntries] = await Promise.all([
  getCollection('articles'),
  getCollection('experiments'),
]);

const entries = [
  ...articleEntries.filter((e) => e.data.status !== 'draft').map((entry) => ({
    slug: entry.slug,
    href: `/articles/${entry.slug}/`,
    title: entry.data.title,
    dek: entry.data.description,
    sortDate: entry.data.date,
    date: monthYear(entry.data.date),
    read: readingTime(entry.body),
    dept: 'Articles',
  })),
  ...experimentEntries.map((entry) => ({
    slug: entry.slug,
    href: `/experiments/${entry.slug}/`,
    title: entry.data.title,
    dek: entry.data.description,
    sortDate: entry.data.date,
    date: monthYear(entry.data.date),
    read: readingTime(entry.body),
    dept: 'Experiments',
  })),
].sort((a, b) => b.sortDate.getTime() - a.sortDate.getTime());

const [lead, ...rest] = entries;
const railItems = rest.slice(0, 2);
const gridItems = rest.slice(2);
---
<BaseLayout title={siteTitle} description={siteDescription} canonical={siteUrl}>
  <main>
    <section class="ed-wrap ed-flag">
      <h1 class="ed-hero">{siteTagline}</h1>
      <p style="font-family:var(--ed-serif);font-style:italic;font-size:1.18rem;line-height:1.55;color:var(--ed-ink-2);max-width:42rem;margin:1.25rem auto 0;">
        AI software lab publishing research, experiments, and methods in a structured format.
      </p>
    </section>

    <section class="ed-wrap" style="padding-top:2.75rem;padding-bottom:1.5rem;">
      <div class="ed-grid3">
        <a class="ed-art" href="/articles/">
          <p class="ed-dept" style="margin-bottom:0.55rem;">Articles</p>
          <h2 class="ed-art-h ed-serif" style="font-size:1.4rem;line-height:1.18;margin:0 0 0.5rem;">Evidence-backed articles</h2>
          <p class="ed-meta" style="font-size:0.92rem;letter-spacing:0.01em;">Studies, analyses, and findings from the lab.</p>
        </a>
        <a class="ed-art" href="/experiments/">
          <p class="ed-dept" style="margin-bottom:0.55rem;">Experiments</p>
          <h2 class="ed-art-h ed-serif" style="font-size:1.4rem;line-height:1.18;margin:0 0 0.5rem;">Tests and prototypes</h2>
          <p class="ed-meta" style="font-size:0.92rem;letter-spacing:0.01em;">Tests, prototypes, and small proofs of concept.</p>
        </a>
        <a class="ed-art" href="/methods/">
          <p class="ed-dept" style="margin-bottom:0.55rem;">Methods</p>
          <h2 class="ed-art-h ed-serif" style="font-size:1.4rem;line-height:1.18;margin:0 0 0.5rem;">How the lab works</h2>
          <p class="ed-meta" style="font-size:0.92rem;letter-spacing:0.01em;">How the lab works and what stays in scope.</p>
        </a>
      </div>
    </section>

    {lead && (
      <section class={`ed-wrap ${railItems.length ? 'ed-front' : ''}`} style="padding-top:4.5rem;padding-bottom:6rem;">
        <a class="ed-art ed-lead" href={lead.href}>
          <p class="ed-dept" style="margin-bottom:0.7rem;">{lead.dept}</p>
          <h2 class="ed-art-h ed-lead-h">{lead.title}</h2>
          <p class="ed-lead-dek">{lead.dek}</p>
          <p class="ed-meta">{lead.read} read</p>
        </a>

        {railItems.length > 0 && (
          <div class="ed-rail">
            {railItems.map((p) => (
              <a class="ed-art" href={p.href}>
                <p class="ed-dept" style="margin-bottom:0.6rem;">{p.dept}</p>
                <h3 class="ed-art-h ed-rail-h">{p.title}</h3>
                <p class="ed-rail-dek">{p.dek}</p>
                <p class="ed-meta">{p.date} · {p.read}</p>
              </a>
            ))}
          </div>
        )}
      </section>
    )}

    {gridItems.length > 0 && (
      <section class="ed-wrap" style="padding-bottom:6rem;">
        <div class="ed-grid3">
          {gridItems.map((p) => (
            <a class="ed-art" href={p.href}>
              <p class="ed-dept" style="margin-bottom:0.55rem;">{p.dept}</p>
              <h3 class="ed-art-h ed-serif" style="font-size:1.35rem;line-height:1.18;margin:0 0 0.5rem;max-width:24ch;">{p.title}</h3>
              <p class="ed-meta">{p.date} · {p.read}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</BaseLayout>
