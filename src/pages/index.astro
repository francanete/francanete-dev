---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { monthYear, readingTime } from '../lib/reading';
import { siteDescription, siteTagline, siteTitle, siteUrl } from '../lib/site';

const [researchEntries, experimentEntries] = await Promise.all([
  getCollection('research'),
  getCollection('experiments'),
]);

const entries = [
  ...researchEntries.filter((e) => e.data.status !== 'draft').map((entry) => ({
    slug: entry.slug,
    href: `/research/${entry.slug}/`,
    title: entry.data.title,
    dek: entry.data.description,
    sortDate: entry.data.date,
    date: monthYear(entry.data.date),
    read: readingTime(entry.body),
    dept: 'Research',
  })),
  ...experimentEntries.filter((e) => e.data.status !== 'draft').map((entry) => ({
    slug: entry.slug,
    href: `/experiments/${entry.slug}/`,
    title: entry.data.title,
    dek: entry.data.description,
    sortDate: entry.data.date,
    date: monthYear(entry.data.date),
    read: readingTime(entry.body),
    dept: 'Experiments',
  })),
].sort((a, b) => b.sortDate.getTime() - a.sortDate.getTime());

const [lead, ...rest] = entries;
const railItems = rest.slice(0, 2);
const gridItems = rest.slice(2);
const dateline = lead ? lead.date : monthYear(new Date());
---
<BaseLayout title={siteTitle} description={siteDescription} canonical={siteUrl}>
  <main>
    <section class="ed-wrap ed-flag">
      <p class="ed-dateline">{dateline}</p>
      <h1 class="ed-hero">{siteTagline}</h1>
    </section>

    {lead && (
      <section class={`ed-wrap ${railItems.length ? 'ed-front' : ''}`} style="padding-top:4.5rem;padding-bottom:6rem;">
        <a class="ed-art ed-lead" href={lead.href}>
          <p class="ed-dept" style="margin-bottom:0.7rem;">{lead.dept}</p>
          <h2 class="ed-art-h ed-lead-h">{lead.title}</h2>
          <p class="ed-lead-dek">{lead.dek}</p>
          <p class="ed-meta">{lead.read} read</p>
        </a>

        {railItems.length > 0 && (
          <div class="ed-rail">
            {railItems.map((p) => (
              <a class="ed-art" href={p.href}>
                <p class="ed-dept" style="margin-bottom:0.6rem;">{p.dept}</p>
                <h3 class="ed-art-h ed-rail-h">{p.title}</h3>
                <p class="ed-rail-dek">{p.dek}</p>
                <p class="ed-meta">{p.date} · {p.read}</p>
              </a>
            ))}
          </div>
        )}
      </section>
    )}

    {gridItems.length > 0 && (
      <section class="ed-wrap" style="padding-bottom:6rem;">
        <div class="ed-grid3">
          {gridItems.map((p) => (
            <a class="ed-art" href={p.href}>
              <p class="ed-dept" style="margin-bottom:0.55rem;">{p.dept}</p>
              <h3 class="ed-art-h ed-serif" style="font-size:1.35rem;line-height:1.18;margin:0 0 0.5rem;max-width:24ch;">{p.title}</h3>
              <p class="ed-meta">{p.date} · {p.read}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</BaseLayout>
