---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { monthYear, readingTime } from '../lib/reading';
import { siteDescription, siteTitle, siteUrl } from '../lib/site';

const entries = (await getCollection('research'))
  .filter((e) => e.data.status !== 'draft')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const pieces = entries.map((entry, i) => ({
  slug: entry.slug,
  title: entry.data.title,
  dek: entry.data.description,
  date: monthYear(entry.data.date),
  read: readingTime(entry.body),
  dept: i === 0 ? 'The Lead · GEO' : 'Research',
  lead: i === 0,
}));
---
<BaseLayout title={siteTitle} description={siteDescription} canonical={siteUrl}>
  <main>
    <section class="ed-wrap" style="padding-top:2.4rem;padding-bottom:4rem;">
      <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:0.4rem;">
        <p class="ed-dept">Latest writing</p>
        <a class="ed-nav" href="/research/">Browse by department →</a>
      </div>

      {pieces.map((p) => (
        <a
          class="ed-art ed-row-sm"
          href={`/research/${p.slug}/`}
          style={`display:grid;grid-template-columns:5.5rem 1fr;gap:1.6rem;align-items:baseline;border-top:1px solid var(--ed-rule);padding:${p.lead ? '1.8rem 0' : '1.4rem 0'};`}
        >
          <span class="ed-meta ed-meta-date" style="padding-top:0.35rem;white-space:nowrap;">{p.date}</span>
          <div>
            <p class="ed-dept" style="margin-bottom:0.4rem;">{p.dept}</p>
            <h2 class="ed-art-h ed-serif" style={`font-size:${p.lead ? 'clamp(1.9rem, 3.4vw, 2.7rem)' : '1.55rem'};line-height:1.16;margin:0;max-width:26ch;`}>{p.title}</h2>
            <p style={`font-family:var(--ed-serif);font-size:${p.lead ? '1.18rem' : '1.05rem'};line-height:1.5;color:var(--ed-ink-2);margin:0.55rem 0 0.6rem;max-width:58ch;`}>{p.dek}</p>
            <p class="ed-meta">{p.read} read</p>
          </div>
        </a>
      ))}
      <hr class="ed-rule" />
    </section>
  </main>
</BaseLayout>
