---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildArticleJsonLd } from '../../lib/schema';
import { monthYear, readingTime } from '../../lib/reading';
import { siteAuthor } from '../../lib/site';

export async function getStaticPaths() {
  const entries = (await getCollection('experiments'))
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const canonical = entry.data.canonical ?? `https://francanete.dev/experiments/${entry.slug}/`;
const jsonLd = [
  buildArticleJsonLd({
    title: entry.data.title,
    description: entry.data.description,
    url: canonical,
    datePublished: entry.data.date,
    dateModified: entry.data.updated,
    keywords: entry.data.tags,
  }),
];
---
<BaseLayout
  title={`${entry.data.title} | francanete.dev`}
  description={entry.data.description}
  canonical={canonical}
  type="article"
  jsonLd={jsonLd}
>
  <main>
    <div class="ed-wrap" style="text-align:center;padding-top:2.6rem;padding-bottom:1.6rem;">
      <p class="ed-dept">Experiment</p>
      <h1 class="ed-serif" style="font-size:clamp(2.3rem, 5vw, 3.8rem);line-height:1.06;margin:0.9rem auto 1.1rem;max-width:20ch;">{entry.data.title}</h1>
      <p style="font-family:var(--ed-serif);font-style:italic;font-size:1.35rem;line-height:1.45;color:var(--ed-ink-2);max-width:44ch;margin:0 auto 1.4rem;">{entry.data.description}</p>
      <div style="display:flex;flex-wrap:wrap;justify-content:center;align-items:center;gap:0.4rem 1.2rem;">
        <span class="ed-meta" style="color:var(--ed-ink);">By {siteAuthor}</span>
        <span class="ed-meta" style="color:var(--ed-accent-d);">Status: {entry.data.status}</span>
        <span class="ed-meta">Published: {entry.data.date.toISOString().slice(0, 10)}</span>
        {entry.data.updated && <span class="ed-meta">Updated: {entry.data.updated.toISOString().slice(0, 10)}</span>}
        <span class="ed-meta">{monthYear(entry.data.date)} · {readingTime(entry.body)}</span>
      </div>
    </div>

    <article class="ed-read ed-prose ed-dropcap" style="margin-top:2.4rem;padding-bottom:3rem;">
      <Content />

      {entry.data.engines.length > 0 && (
        <div style="margin-top:2.8rem;">
          <p class="ed-dept" style="margin-bottom:0.6rem;">Engines used</p>
          <p style="font-family:var(--ed-sans);font-size:0.92rem;color:var(--ed-ink-2);letter-spacing:0.01em;margin:0;">{entry.data.engines.join('  ·  ')}</p>
        </div>
      )}

      <div style="margin-top:3rem;padding-top:1.2rem;border-top:1px solid var(--ed-rule);">
        <p class="ed-dept" style="margin-bottom:0.7rem;">Continue reading</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.75rem 1.25rem;">
          <a class="ed-nav" href="/experiments/">All experiments</a>
          <a class="ed-nav" href="/research/">Research</a>
          <a class="ed-nav" href="/methodology/">Methodology</a>
          <a class="ed-nav" href="/">Cover</a>
        </div>
      </div>
    </article>
  </main>
</BaseLayout>
