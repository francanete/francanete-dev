---
import { siteAuthor, siteDescription, siteTagline, siteTitle, siteUrl } from '../lib/site';
import { buildWebsiteJsonLd } from '../lib/schema';

const {
  title = siteTitle,
  description = siteDescription,
  canonical = siteUrl,
  type = 'website',
  jsonLd = [],
} = Astro.props;

const allJsonLd = [buildWebsiteJsonLd(), ...jsonLd];
const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));

// Only departments with real content are surfaced.
const nav = [
  { href: '/', label: 'Cover' },
  { href: '/research/', label: 'Research' },
  { href: '/methodology/', label: 'Methodology' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index,follow" />
    <meta name="author" content={siteAuthor} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteTitle} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#f7f3ea" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/Newsreader-Variable.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/HankenGrotesk-Variable.woff2" crossorigin />
    {allJsonLd.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
    <style is:global>
      /* ---------------------------------------------------------- FONTS */
      @font-face {
        font-family: "Newsreader";
        src: url("/fonts/Newsreader-Variable.woff2") format("woff2");
        font-weight: 400 700; font-style: normal; font-display: swap;
      }
      @font-face {
        font-family: "Newsreader";
        src: url("/fonts/Newsreader-Italic-Variable.woff2") format("woff2");
        font-weight: 400 700; font-style: italic; font-display: swap;
      }
      @font-face {
        font-family: "Hanken Grotesk";
        src: url("/fonts/HankenGrotesk-Variable.woff2") format("woff2");
        font-weight: 400 700; font-style: normal; font-display: swap;
      }
      @font-face {
        font-family: "JetBrains Mono";
        src: url("/fonts/JetBrainsMono-Variable.woff2") format("woff2");
        font-weight: 400 700; font-style: normal; font-display: swap;
      }

      /* --------------------------------------------------------- TOKENS */
      /* The Review: warm ivory, brown-black ink, editorial terracotta */
      :root {
        color-scheme: light;
        --ed-paper:   #f7f3ea;
        --ed-paper-2: #efe7d7;
        --ed-paper-3: #f2ecdf;
        --ed-ink:     #211a12;
        --ed-ink-2:   #574d40;
        --ed-ink-3:   #8c8170;
        --ed-rule:    rgba(33,26,18,0.16);
        --ed-rule-2:  rgba(33,26,18,0.32);
        --ed-accent:  #a8502b;
        --ed-accent-d:#883e1e;

        --ed-serif: "Newsreader", Georgia, "Times New Roman", serif;
        --ed-sans:  "Hanken Grotesk", system-ui, -apple-system, sans-serif;
        --ed-mono:  "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;

        --ed-wrap: min(100% - 2.5rem, 74rem);
        --ed-read: min(100% - 2.5rem, 40rem);
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background:
          radial-gradient(120% 72% at 50% -8%, #fdfaf3 0%, var(--ed-paper) 46%, var(--ed-paper-3) 100%)
          var(--ed-paper) fixed;
        color: var(--ed-ink);
        font-family: var(--ed-serif);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      ::selection { background: #e7c3ab; color: var(--ed-ink); }
      a { color: inherit; cursor: pointer; -webkit-tap-highlight-color: transparent; }

      /* ------------------------------------------------------- HELPERS */
      .ed-wrap  { width: var(--ed-wrap); margin-inline: auto; }
      .ed-read  { width: var(--ed-read); margin-inline: auto; }
      .ed-shell { min-height: 100vh; display: flex; flex-direction: column; }

      .ed-dept { font-family: var(--ed-sans); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ed-accent-d); margin: 0; }
      .ed-meta { font-family: var(--ed-sans); font-size: 0.78rem; letter-spacing: 0.04em; color: var(--ed-ink-3); }
      .ed-serif { font-family: var(--ed-serif); font-weight: 600; letter-spacing: -0.02em; }
      .ed-ital { font-style: italic; color: var(--ed-accent-d); }

      /* nav — centered, growing underline */
      .ed-nav { font-family: var(--ed-sans); font-size: 0.74rem; font-weight: 600; letter-spacing: 0.08em; color: var(--ed-ink-2); text-decoration: none; padding: 0.18rem 0; position: relative; transition: color 140ms ease; text-transform: uppercase; }
      .ed-nav::after { content: ""; position: absolute; left: 50%; right: 50%; bottom: -1px; height: 1px; background: var(--ed-accent); transition: left 180ms ease, right 180ms ease; }
      .ed-nav:hover { color: var(--ed-ink); }
      .ed-nav:hover::after, .ed-nav.on::after { left: 0; right: 0; }
      .ed-nav.on { color: var(--ed-ink); }

      /* article entry in lists */
      .ed-art { display: block; text-decoration: none; color: inherit; transition: opacity 140ms ease; }
      .ed-art:hover .ed-art-h { color: var(--ed-accent-d); }
      .ed-art-h { transition: color 150ms ease; }

      .ed-link { color: var(--ed-accent-d); text-decoration: none; box-shadow: inset 0 -1px 0 var(--ed-accent); }
      .ed-link:hover { background: #e7c3ab; }

      .ed-btn { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--ed-sans); font-size: 0.85rem; font-weight: 600; letter-spacing: 0.02em; padding: 0.8rem 1.4rem; background: var(--ed-ink); color: var(--ed-paper); border: 1px solid var(--ed-ink); text-decoration: none; transition: all 150ms ease; }
      .ed-btn:hover { background: var(--ed-accent-d); border-color: var(--ed-accent-d); }
      .ed-btn.ghost { background: transparent; color: var(--ed-ink); }
      .ed-btn.ghost:hover { background: var(--ed-ink); color: var(--ed-paper); }

      .ed-rule { border: 0; border-top: 1px solid var(--ed-rule); margin: 0; }

      /* ---------------------------------------------------- MASTHEAD */
      .ed-header {
        position: sticky; top: 0; z-index: 30;
        background: rgba(248,244,236,0.72);
        backdrop-filter: saturate(1.1) blur(10px);
        -webkit-backdrop-filter: saturate(1.1) blur(10px);
      }
      .ed-headerbar {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
        min-height: 3.75rem;
      }
      .ed-headerbar a { text-decoration: none; color: var(--ed-ink); }
      .ed-brand { justify-self: start; font-family: var(--ed-serif); font-weight: 600; letter-spacing: -0.01em; font-size: 1.02rem; line-height: 1; }
      .ed-brand .tld { color: var(--ed-accent); }
      .ed-subhead { justify-self: center; margin: 0; font-family: var(--ed-sans); font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ed-ink-3); text-align: center; }
      /* the cover promotes the tagline to a hero, so hide the running one there */
      .is-cover .ed-subhead { display: none; }
      .ed-navbar { justify-self: end; }
      .ed-navlinks { display: flex; justify-content: flex-end; gap: 1rem; flex-wrap: wrap; }

      /* ------------------------------------------------------ FOOTER */
      .ed-footer { margin-top: auto; background: transparent; }
      .ed-footer-inner { min-height: 5rem; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 1rem; }
      .ed-footer-mark { justify-self: start; font-family: var(--ed-serif); font-weight: 600; letter-spacing: -0.01em; font-size: 1.02rem; }
      .ed-footer-mark .tld { color: var(--ed-accent); }
      .ed-footer-links { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }

      /* --------------------------------------------------- ARTICLE PROSE */
      .ed-drop::first-letter,
      .ed-prose.ed-dropcap > p:first-of-type::first-letter {
        font-family: var(--ed-serif); font-weight: 600; float: left;
        font-size: 4.4rem; line-height: 0.74; padding: 0.28rem 0.7rem 0 0; color: var(--ed-accent-d);
      }
      .ed-prose { font-family: var(--ed-serif); font-size: 1.22rem; line-height: 1.74; color: var(--ed-ink); }
      .ed-prose > :first-child { margin-top: 0; }
      .ed-prose p { margin: 0 0 1.25rem; }
      .ed-prose strong { font-weight: 600; color: var(--ed-ink); }
      .ed-prose em { font-style: italic; }
      .ed-prose a { color: var(--ed-accent-d); text-decoration: none; box-shadow: inset 0 -1px 0 var(--ed-accent); }
      .ed-prose a:hover { background: #e7c3ab; }
      .ed-prose h2 { font-family: var(--ed-serif); font-weight: 600; letter-spacing: -0.02em; font-size: 1.7rem; line-height: 1.15; margin: 2.6rem 0 0.8rem; }
      .ed-prose h3 { font-family: var(--ed-serif); font-weight: 600; letter-spacing: -0.02em; font-size: 1.32rem; line-height: 1.2; margin: 2rem 0 0.5rem; }
      .ed-prose ul, .ed-prose ol { padding-left: 1.4rem; margin: 0 0 1.25rem; }
      .ed-prose li { margin: 0 0 0.5rem; }
      .ed-prose li::marker { color: var(--ed-accent); }
      .ed-prose blockquote {
        margin: 2.6rem 0; padding: 0;
        font-family: var(--ed-serif); font-weight: 500; font-size: 1.62rem; line-height: 1.36; color: var(--ed-accent-d); font-style: italic;
      }
      .ed-prose blockquote p { margin: 0 0 0.6rem; }
      .ed-prose code { font-family: var(--ed-mono); font-size: 0.84em; background: var(--ed-paper-2); padding: 0.12rem 0.34rem; border-radius: 2px; }
      .ed-prose pre { background: var(--ed-ink); color: var(--ed-paper); padding: 1.1rem 1.2rem; overflow: auto; font-family: var(--ed-mono); font-size: 0.86rem; line-height: 1.6; border-radius: 3px; }
      .ed-prose pre code { background: none; border: none; padding: 0; color: inherit; font-size: inherit; }
      .ed-prose table { width: 100%; border-collapse: collapse; margin: 1.9rem 0; font-family: var(--ed-sans); font-size: 0.95rem; }
      .ed-prose th, .ed-prose td { padding: 0.7rem 1.2rem 0.7rem 0; vertical-align: top; text-align: left; }
      .ed-prose th { border-bottom: 1px solid var(--ed-ink); font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; color: var(--ed-ink-2); }

      /* --------------------------------------------- EDITORIAL FURNITURE */
      .ed-dateline { font-family: var(--ed-sans); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.24em; text-transform: uppercase; color: var(--ed-ink-3); margin: 0; }

      /* ----------------------------------------------------- COVER FLAG */
      .ed-flag { text-align: center; padding-top: 4rem; }
      .ed-hero {
        font-family: var(--ed-serif); font-weight: 600; letter-spacing: -0.025em;
        font-size: clamp(2.4rem, 6vw, 5rem); line-height: 1.04;
        margin: 1.2rem auto 0; max-width: 16ch; color: var(--ed-ink);
        text-wrap: balance;
      }
      .ed-hero em { font-style: italic; color: var(--ed-accent-d); }

      /* ------------------------------------------------- FRONT-PAGE GRID */
      .ed-front { display: grid; grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr); gap: 5.5rem; align-items: start; }
      .ed-lead-h { font-family: var(--ed-serif); font-weight: 600; letter-spacing: -0.025em; font-size: clamp(2.1rem, 4vw, 3.4rem); line-height: 1.07; margin: 0; max-width: 18ch; }
      .ed-lead-dek { font-family: var(--ed-serif); font-size: 1.26rem; line-height: 1.56; color: var(--ed-ink-2); margin: 1rem 0; max-width: 42ch; }
      .ed-rail { display: flex; flex-direction: column; gap: 2.8rem; }
      .ed-rail-h { font-family: var(--ed-serif); font-weight: 600; letter-spacing: -0.018em; font-size: 1.45rem; line-height: 1.16; margin: 0; }
      .ed-rail-dek { font-family: var(--ed-serif); font-size: 1.04rem; line-height: 1.5; color: var(--ed-ink-2); margin: 0.55rem 0; }

      /* overflow beyond lead + rail */
      .ed-grid3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3.4rem; margin-top: 4rem; }

      /* ------------------------------------------------------- FEED LIST */
      .ed-feed-row { display: block; max-width: 62ch; margin-inline: auto; padding: 2.8rem 0; }
      .ed-feed-row:first-child { padding-top: 0.6rem; }
      .ed-feed-h { font-family: var(--ed-serif); font-weight: 600; letter-spacing: -0.02em; font-size: 1.9rem; line-height: 1.12; margin: 0.55rem 0; max-width: 26ch; }
      .ed-feed-dek { font-family: var(--ed-serif); font-size: 1.1rem; line-height: 1.55; color: var(--ed-ink-2); margin: 0 0 0.8rem; max-width: 56ch; }

      @media (prefers-reduced-motion: reduce) {
        .ed-nav::after, .ed-art-h, .ed-btn { transition: none; }
      }
      @media (max-width: 820px) {
        .ed-2col { grid-template-columns: 1fr !important; }
        .ed-hide-sm { display: none !important; }
        .ed-headerbar {
          grid-template-columns: 1fr;
          gap: 0.35rem;
          padding-top: 0.45rem;
          padding-bottom: 0.45rem;
        }
        .ed-brand,
        .ed-subhead,
        .ed-navbar {
          justify-self: center;
        }
        .ed-navbar {
          width: 100%;
        }
        .ed-navlinks {
          justify-content: center;
          gap: 1.1rem;
          margin-top: 0.1rem;
        }
        .ed-nav {
          font-size: 0.7rem;
        }
        .ed-front { grid-template-columns: 1fr; gap: 2.8rem; }
        .ed-rail { margin-top: 0; gap: 2.6rem; padding-top: 0; }
        .ed-grid3 { grid-template-columns: 1fr; gap: 2.6rem; margin-top: 2.8rem; }
        .ed-hero { font-size: clamp(2rem, 8.5vw, 3.2rem); }
      }
      @media (max-width: 540px) {
        .ed-feed-row { padding: 2rem 0; }
        .ed-feed-h { font-size: 1.6rem; }
        .ed-row-sm { grid-template-columns: 1fr !important; gap: 0.5rem !important; }
        .ed-row-sm .ed-meta-date { padding-top: 0 !important; }
      }
    </style>
  </head>
  <body class={path === '/' ? 'is-cover' : ''}>
    <div class="ed-shell">
      <header class="ed-header">
        <div class="ed-wrap ed-headerbar">
          <a class="ed-brand" href="/">francanete<span class="tld">.dev</span></a>
          <p class="ed-subhead">{siteTagline}</p>
          <nav class="ed-navbar" aria-label="Primary">
            <div class="ed-navlinks">
              {nav.map((item) => (
                <a class={`ed-nav${isActive(item.href) ? ' on' : ''}`} href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                  {item.label}
                </a>
              ))}
            </div>
          </nav>
        </div>
      </header>

      <slot />

      <footer class="ed-footer">
        <div class="ed-wrap ed-footer-inner">
          <span class="ed-footer-mark">francanete<span class="tld">.dev</span></span>
          <div class="ed-footer-links">
            <a class="ed-nav" href="/research/">Research</a>
            <a class="ed-nav" href="/methodology/">Methodology</a>
            <a class="ed-nav" href="/rss.xml">RSS</a>
          </div>
          <span class="ed-meta" style="justify-self:end;">© 2026</span>
        </div>
      </footer>
    </div>
  </body>
</html>
