---
import { siteAuthor, siteDescription, siteTitle, siteUrl } from '../lib/site';
import { buildWebsiteJsonLd } from '../lib/schema';

const {
  title = siteTitle,
  description = siteDescription,
  canonical = siteUrl,
  type = 'website',
  jsonLd = [],
} = Astro.props;

const allJsonLd = [buildWebsiteJsonLd(), ...jsonLd];
const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));

// Only departments with real content are surfaced.
const nav = [
  { href: '/', label: 'Cover' },
  { href: '/research/', label: 'Research' },
  { href: '/methodology/', label: 'Methodology' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index,follow" />
    <meta name="author" content={siteAuthor} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteTitle} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#f7f3ea" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/Newsreader-Variable.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/HankenGrotesk-Variable.woff2" crossorigin />
    {allJsonLd.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
    <style is:global>
      /* ---------------------------------------------------------- FONTS */
      @font-face {
        font-family: "Newsreader";
        src: url("/fonts/Newsreader-Variable.woff2") format("woff2");
        font-weight: 400 700; font-style: normal; font-display: swap;
      }
      @font-face {
        font-family: "Newsreader";
        src: url("/fonts/Newsreader-Italic-Variable.woff2") format("woff2");
        font-weight: 400 700; font-style: italic; font-display: swap;
      }
      @font-face {
        font-family: "Hanken Grotesk";
        src: url("/fonts/HankenGrotesk-Variable.woff2") format("woff2");
        font-weight: 400 700; font-style: normal; font-display: swap;
      }
      @font-face {
        font-family: "JetBrains Mono";
        src: url("/fonts/JetBrainsMono-Variable.woff2") format("woff2");
        font-weight: 400 700; font-style: normal; font-display: swap;
      }

      /* --------------------------------------------------------- TOKENS */
      /* The Review: warm ivory, brown-black ink, editorial terracotta */
      :root {
        color-scheme: light;
        --ed-paper:   #f7f3ea;
        --ed-paper-2: #efe7d7;
        --ed-paper-3: #f2ecdf;
        --ed-ink:     #211a12;
        --ed-ink-2:   #574d40;
        --ed-ink-3:   #8c8170;
        --ed-rule:    rgba(33,26,18,0.16);
        --ed-rule-2:  rgba(33,26,18,0.32);
        --ed-accent:  #a8502b;
        --ed-accent-d:#883e1e;

        --ed-serif: "Newsreader", Georgia, "Times New Roman", serif;
        --ed-sans:  "Hanken Grotesk", system-ui, -apple-system, sans-serif;
        --ed-mono:  "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;

        --ed-wrap: min(100% - 2.5rem, 74rem);
        --ed-read: min(100% - 2.5rem, 40rem);
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--ed-paper);
        color: var(--ed-ink);
        font-family: var(--ed-serif);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      ::selection { background: #e7c3ab; color: var(--ed-ink); }
      a { color: inherit; cursor: pointer; -webkit-tap-highlight-color: transparent; }

      /* ------------------------------------------------------- HELPERS */
      .ed-wrap  { width: var(--ed-wrap); margin-inline: auto; }
      .ed-read  { width: var(--ed-read); margin-inline: auto; }
      .ed-shell { min-height: 100vh; display: flex; flex-direction: column; }

      .ed-dept { font-family: var(--ed-sans); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ed-accent-d); margin: 0; }
      .ed-meta { font-family: var(--ed-sans); font-size: 0.78rem; letter-spacing: 0.04em; color: var(--ed-ink-3); }
      .ed-serif { font-family: var(--ed-serif); font-weight: 600; letter-spacing: -0.02em; }
      .ed-ital { font-style: italic; color: var(--ed-accent-d); }

      /* nav — centered, growing underline */
      .ed-nav { font-family: var(--ed-sans); font-size: 0.82rem; font-weight: 600; letter-spacing: 0.04em; color: var(--ed-ink-2); text-decoration: none; padding: 0.35rem 0; position: relative; transition: color 140ms ease; }
      .ed-nav::after { content: ""; position: absolute; left: 50%; right: 50%; bottom: 0; height: 1.5px; background: var(--ed-accent); transition: left 180ms ease, right 180ms ease; }
      .ed-nav:hover { color: var(--ed-ink); }
      .ed-nav:hover::after, .ed-nav.on::after { left: 0; right: 0; }
      .ed-nav.on { color: var(--ed-ink); }

      /* article entry in lists */
      .ed-art { display: block; text-decoration: none; color: inherit; transition: opacity 140ms ease; }
      .ed-art:hover .ed-art-h { color: var(--ed-accent-d); }
      .ed-art-h { transition: color 150ms ease; }

      .ed-link { color: var(--ed-accent-d); text-decoration: none; box-shadow: inset 0 -1px 0 var(--ed-accent); }
      .ed-link:hover { background: #e7c3ab; }

      .ed-btn { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--ed-sans); font-size: 0.85rem; font-weight: 600; letter-spacing: 0.02em; padding: 0.8rem 1.4rem; background: var(--ed-ink); color: var(--ed-paper); border: 1px solid var(--ed-ink); text-decoration: none; transition: all 150ms ease; }
      .ed-btn:hover { background: var(--ed-accent-d); border-color: var(--ed-accent-d); }
      .ed-btn.ghost { background: transparent; color: var(--ed-ink); }
      .ed-btn.ghost:hover { background: var(--ed-ink); color: var(--ed-paper); }

      .ed-rule { border: 0; border-top: 1px solid var(--ed-rule); margin: 0; }

      /* ---------------------------------------------------- MASTHEAD */
      .ed-header { background: var(--ed-paper); border-bottom: 2px solid var(--ed-ink); position: sticky; top: 0; z-index: 30; }
      .ed-dateline { display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0; font-family: var(--ed-mono); font-size: 0.64rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ed-ink-3); }
      .ed-titlebar { text-align: center; border-top: 1px solid var(--ed-rule); padding-top: 0.9rem; padding-bottom: 0.2rem; }
      .ed-titlebar a { text-decoration: none; color: var(--ed-ink); }
      .ed-wordmark { font-family: var(--ed-serif); font-weight: 600; letter-spacing: -0.01em; font-size: clamp(1.8rem, 4.4vw, 2.6rem); line-height: 1; }
      .ed-wordmark .tld { color: var(--ed-accent); }
      .ed-navbar { border-top: 1px solid var(--ed-rule); margin-top: 0.8rem; border-bottom: 1px solid var(--ed-rule); }
      .ed-navlinks { display: flex; justify-content: center; gap: 2.2rem; flex-wrap: wrap; padding: 0.6rem 0; }

      /* ------------------------------------------------------ FOOTER */
      .ed-footer { border-top: 2px solid var(--ed-ink); margin-top: auto; background: var(--ed-paper); }
      .ed-footer-inner { padding-top: 2.2rem; padding-bottom: 2.2rem; display: flex; justify-content: space-between; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
      .ed-footer-mark { font-family: var(--ed-serif); font-weight: 600; letter-spacing: -0.02em; font-size: 1.4rem; }
      .ed-footer-mark .tld { color: var(--ed-accent); }
      .ed-footer-links { display: flex; gap: 1.6rem; flex-wrap: wrap; }

      /* --------------------------------------------------- ARTICLE PROSE */
      .ed-drop::first-letter,
      .ed-prose.ed-dropcap > p:first-of-type::first-letter {
        font-family: var(--ed-serif); font-weight: 600; float: left;
        font-size: 4.4rem; line-height: 0.74; padding: 0.28rem 0.7rem 0 0; color: var(--ed-accent-d);
      }
      .ed-prose { font-family: var(--ed-serif); font-size: 1.22rem; line-height: 1.74; color: var(--ed-ink); }
      .ed-prose > :first-child { margin-top: 0; }
      .ed-prose p { margin: 0 0 1.25rem; }
      .ed-prose strong { font-weight: 600; color: var(--ed-ink); }
      .ed-prose em { font-style: italic; }
      .ed-prose a { color: var(--ed-accent-d); text-decoration: none; box-shadow: inset 0 -1px 0 var(--ed-accent); }
      .ed-prose a:hover { background: #e7c3ab; }
      .ed-prose h2 { font-family: var(--ed-serif); font-weight: 600; letter-spacing: -0.02em; font-size: 1.7rem; line-height: 1.15; margin: 2.6rem 0 0.8rem; }
      .ed-prose h3 { font-family: var(--ed-serif); font-weight: 600; letter-spacing: -0.02em; font-size: 1.32rem; line-height: 1.2; margin: 2rem 0 0.5rem; }
      .ed-prose ul, .ed-prose ol { padding-left: 1.4rem; margin: 0 0 1.25rem; }
      .ed-prose li { margin: 0 0 0.5rem; }
      .ed-prose li::marker { color: var(--ed-accent); }
      .ed-prose blockquote {
        margin: 2rem 0; border-left: 2px solid var(--ed-accent); padding-left: 1.4rem;
        font-family: var(--ed-serif); font-weight: 500; font-size: 1.5rem; line-height: 1.3; color: var(--ed-ink); font-style: normal;
      }
      .ed-prose blockquote p { margin: 0 0 0.6rem; }
      .ed-prose code { font-family: var(--ed-mono); font-size: 0.84em; background: var(--ed-paper-2); border: 1px solid var(--ed-rule); padding: 0.1rem 0.3rem; }
      .ed-prose pre { background: var(--ed-ink); color: var(--ed-paper); padding: 1.1rem 1.2rem; overflow: auto; font-family: var(--ed-mono); font-size: 0.86rem; line-height: 1.6; }
      .ed-prose pre code { background: none; border: none; padding: 0; color: inherit; font-size: inherit; }
      .ed-prose table { width: 100%; border-collapse: collapse; margin: 1.75rem 0; font-family: var(--ed-sans); font-size: 0.95rem; }
      .ed-prose th, .ed-prose td { border: 1px solid var(--ed-rule-2); padding: 0.7rem 0.85rem; vertical-align: top; text-align: left; }
      .ed-prose th { background: var(--ed-paper-2); font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; }

      @media (prefers-reduced-motion: reduce) {
        .ed-nav::after, .ed-art-h, .ed-btn { transition: none; }
      }
      @media (max-width: 820px) {
        .ed-2col { grid-template-columns: 1fr !important; }
        .ed-hide-sm { display: none !important; }
      }
      @media (max-width: 540px) {
        .ed-row-sm { grid-template-columns: 1fr !important; gap: 0.5rem !important; }
        .ed-row-sm .ed-meta-date { padding-top: 0 !important; }
      }
    </style>
  </head>
  <body>
    <div class="ed-shell">
      <header class="ed-header">
        <div class="ed-wrap ed-dateline">
          <span>Vol. I</span>
          <span class="ed-hide-sm">A journal on how machines read the web</span>
          <span>No. 01 · 2026</span>
        </div>
        <div class="ed-wrap ed-titlebar">
          <a href="/"><span class="ed-wordmark">francanete<span class="tld">.dev</span></span></a>
        </div>
        <div class="ed-navbar">
          <nav class="ed-wrap ed-navlinks" aria-label="Primary">
            {nav.map((item) => (
              <a class={`ed-nav${isActive(item.href) ? ' on' : ''}`} href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            ))}
          </nav>
        </div>
      </header>

      <slot />

      <footer class="ed-footer">
        <div class="ed-wrap ed-footer-inner">
          <span class="ed-footer-mark">francanete<span class="tld">.dev</span></span>
          <div class="ed-footer-links">
            <a class="ed-nav" href="/research/">Research</a>
            <a class="ed-nav" href="/methodology/">Methodology</a>
            <a class="ed-nav" href="/rss.xml">RSS</a>
          </div>
          <span class="ed-meta">© 2026 francanete.dev</span>
        </div>
      </footer>
    </div>
  </body>
</html>
