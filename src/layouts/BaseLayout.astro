---
import { primaryNav, siteAuthor, siteDescription, siteTitle, siteUrl } from '../lib/site';
import { buildWebsiteJsonLd } from '../lib/schema';

const {
  title = siteTitle,
  description = siteDescription,
  canonical = siteUrl,
  type = 'website',
  jsonLd = [],
} = Astro.props;

const allJsonLd = [buildWebsiteJsonLd(), ...jsonLd];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index,follow" />
    <meta name="author" content={siteAuthor} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteTitle} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#fbfaf7" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {allJsonLd.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
    <style>
      :root {
        color-scheme: light;
        --bg: #fbfaf7;
        --surface: #ffffff;
        --surface-soft: #f4efe7;
        --border: #e6ded2;
        --border-strong: #cdbfae;
        --text: #1c1917;
        --muted: #6f655b;
        --accent: #8a4b2c;
        --accent-soft: #f3e2d7;
        --shadow: 0 18px 50px rgba(55, 42, 31, 0.08);
        --max: 64rem;
        --reading: 68ch;
      }

      * { box-sizing: border-box; }

      html {
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      body {
        margin: 0;
        background:
          radial-gradient(circle at top left, rgba(138, 75, 44, 0.12), transparent 26rem),
          linear-gradient(180deg, #fffdf9 0%, var(--bg) 22rem);
        color: var(--text);
        line-height: 1.75;
        text-rendering: optimizeLegibility;
      }

      a {
        color: var(--accent);
        text-underline-offset: 0.18em;
      }

      a:hover { text-decoration: none; }

      .site-shell {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .site-header {
        border-bottom: 1px solid rgba(230, 222, 210, 0.8);
        background: rgba(251, 250, 247, 0.82);
        backdrop-filter: blur(14px);
        position: sticky;
        top: 0;
        z-index: 10;
      }

      .site-header-inner,
      .site-footer-inner,
      .page {
        width: min(calc(100% - 2rem), var(--max));
        margin: 0 auto;
      }

      .site-header-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1.5rem;
        padding: 1rem 0;
      }

      .brand {
        color: var(--text);
        text-decoration: none;
        font-family: ui-serif, Georgia, Cambria, "Times New Roman", serif;
        font-size: 1.12rem;
        font-weight: 700;
        letter-spacing: -0.025em;
      }

      .nav {
        display: flex;
        gap: 0.25rem;
        flex-wrap: wrap;
      }

      .nav a {
        border-radius: 999px;
        color: var(--muted);
        font-size: 0.92rem;
        font-weight: 600;
        padding: 0.42rem 0.72rem;
        text-decoration: none;
      }

      .nav a:hover,
      .nav a[aria-current='page'] {
        background: var(--accent-soft);
        color: var(--accent);
      }

      .page {
        flex: 1;
        padding: 5rem 0 5.5rem;
      }

      main, article {
        width: min(100%, var(--reading));
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        margin-bottom: 1.25rem;
        padding: 0.35rem 0.7rem;
        border: 1px solid rgba(138, 75, 44, 0.18);
        border-radius: 999px;
        background: rgba(243, 226, 215, 0.7);
        color: var(--accent);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1, h2, h3 {
        color: var(--text);
        line-height: 1.05;
        letter-spacing: -0.045em;
      }

      h1 {
        max-width: 12ch;
        font-family: ui-serif, Georgia, Cambria, "Times New Roman", serif;
        font-size: clamp(3.1rem, 9vw, 6.4rem);
        font-weight: 740;
        margin: 0 0 1.4rem;
      }

      h2 {
        margin: 3.25rem 0 1rem;
        font-family: ui-serif, Georgia, Cambria, "Times New Roman", serif;
        font-size: clamp(1.75rem, 4vw, 2.6rem);
      }

      h3 {
        margin: 2.25rem 0 0.65rem;
        font-size: 1.2rem;
        letter-spacing: -0.025em;
      }

      p, li { color: var(--text); }

      p {
        margin: 0 0 1.1rem;
      }

      li + li {
        margin-top: 0.35rem;
      }

      ul, ol {
        padding-left: 1.3rem;
      }

      li::marker {
        color: var(--accent);
      }

      .lede {
        color: #3f3933;
        font-size: clamp(1.18rem, 2vw, 1.42rem);
        line-height: 1.55;
      }

      .muted { color: var(--muted); }

      .stack {
        display: grid;
        gap: 1.35rem;
      }

      .hero-grid {
        display: grid;
        gap: 1.25rem;
      }

      .hero-panel {
        padding: 1.5rem;
        border: 1px solid var(--border);
        border-radius: 1.75rem;
        background:
          linear-gradient(180deg, rgba(255,255,255,0.88), rgba(244,239,231,0.8)),
          radial-gradient(circle at top right, rgba(138,75,44,0.14), transparent 14rem);
        box-shadow: var(--shadow);
      }

      .hero-panel--accent {
        background:
          linear-gradient(135deg, rgba(138,75,44,0.12), rgba(255,255,255,0.88) 50%),
          linear-gradient(180deg, rgba(255,255,255,0.95), rgba(244,239,231,0.9));
      }

      .hero-kicker {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1rem;
      }

      .stat-grid {
        display: grid;
        gap: 0.85rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        margin-top: 1rem;
      }

      .stat {
        padding: 0.85rem 0.95rem;
        border-radius: 1rem;
        border: 1px solid rgba(138,75,44,0.14);
        background: rgba(255,255,255,0.72);
      }

      .stat strong {
        display: block;
        font-size: 1rem;
        margin-bottom: 0.2rem;
      }

      .callout {
        padding: 1rem 1.1rem;
        border-left: 4px solid var(--accent);
        border-radius: 0 1rem 1rem 0;
        background: rgba(255,255,255,0.68);
      }

      .callout p:last-child {
        margin-bottom: 0;
      }

      .section {
        margin-top: 3.5rem;
      }

      .card-grid {
        display: grid;
        gap: 1rem;
      }

      .card {
        display: block;
        padding: 1.25rem 1.35rem;
        border: 1px solid var(--border);
        border-radius: 1.25rem;
        background: rgba(255, 255, 255, 0.76);
        box-shadow: 0 1px 0 rgba(255, 255, 255, 0.9) inset;
        color: inherit;
        text-decoration: none;
        transition: border-color 140ms ease, box-shadow 140ms ease, transform 140ms ease;
      }

      .card:hover {
        border-color: var(--border-strong);
        box-shadow: var(--shadow);
        transform: translateY(-2px);
      }

      .card strong {
        display: block;
        font-size: 1.08rem;
        letter-spacing: -0.02em;
        line-height: 1.25;
        margin-bottom: 0.4rem;
      }

      .card p:last-child {
        margin-bottom: 0;
      }

      .meta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
        margin: 1rem 0 1.5rem;
        color: var(--muted);
        font-size: 0.92rem;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.22rem 0.62rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.74);
        color: var(--muted);
        font-size: 0.86rem;
      }

      article {
        max-width: var(--reading);
      }

      article :global(h2) {
        padding-top: 0.5rem;
        border-top: 1px solid var(--border);
      }

      article :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 1.75rem 0;
        overflow: hidden;
        border-radius: 0.85rem;
        background: var(--surface);
      }

      article :global(th),
      article :global(td) {
        border: 1px solid var(--border);
        padding: 0.85rem;
        vertical-align: top;
      }

      article :global(th) {
        background: var(--surface-soft);
        text-align: left;
      }

      article :global(blockquote) {
        margin: 1.75rem 0;
        padding: 1rem 1.25rem;
        border-left: 4px solid var(--accent);
        border-radius: 0 1rem 1rem 0;
        background: rgba(255, 255, 255, 0.6);
        color: var(--muted);
      }

      article :global(code) {
        border: 1px solid var(--border);
        border-radius: 0.35rem;
        background: rgba(255, 255, 255, 0.7);
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.9em;
        padding: 0.1rem 0.25rem;
      }

      .site-footer {
        border-top: 1px solid var(--border);
        margin-top: auto;
        background: rgba(255, 255, 255, 0.45);
      }

      .site-footer-inner {
        padding: 1.5rem 0 2.25rem;
        color: var(--muted);
        font-size: 0.92rem;
      }

      .site-footer-inner p {
        margin: 0.35rem 0;
      }

      @media (max-width: 720px) {
        .site-header-inner {
          align-items: flex-start;
          flex-direction: column;
        }

        .page {
          padding-top: 3rem;
        }

        h1 {
          max-width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header-inner">
          <a class="brand" href="/">francanete.dev</a>
          <nav class="nav" aria-label="Primary">
            {primaryNav.map((item) => (
              <a href={item.href} aria-current={Astro.url.pathname === item.href ? 'page' : undefined}>
                {item.label}
              </a>
            ))}
          </nav>
        </div>
      </header>
      <div class="page">
        <slot />
      </div>
      <footer class="site-footer">
        <div class="site-footer-inner">
          <p>{siteDescription}</p>
          <p>
            Static, crawlable pages. No auth, no dashboard, no CMS-first complexity.
          </p>
        </div>
      </footer>
    </div>
  </body>
</html>
